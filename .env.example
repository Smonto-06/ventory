# ============================================================
# VENTORY — Environment Variables Template
# Copy to .env.local for local development
# NEVER commit .env.local or any file with real secrets
# ============================================================

# ── App ─────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (PostgreSQL via Prisma) ────────────────────────
# Dev:        postgresql://user:pass@localhost:5432/ventory_dev
# Staging:    Set in Railway dashboard — never commit
# Production: Set in Railway dashboard — never commit
DATABASE_URL=postgresql://ventory:ventory_dev@localhost:5432/ventory_dev

# ── NextAuth.js ──────────────────────────────────────────────
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secure-random-secret-here

# ── Sentry (Error Monitoring) ────────────────────────────────
# Only active in staging and production — leave blank for local dev
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=ventory
SENTRY_PROJECT=ventory

# ── Cloudflare R2 (File Storage) ────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ventory-files
R2_PUBLIC_URL=

# ── Railway ──────────────────────────────────────────────────
# Injected automatically by Railway — leave blank locally
RAILWAY_ENVIRONMENT=
